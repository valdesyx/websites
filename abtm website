  section {
    max-width: 1000px;
    margin: auto;
    padding: 80px 20px;
  }

  h2 {
    font-size: 28px;
    margin-bottom: 25px;
    position: relative;
    display: inline-block;
    padding: 0 18px;
  }

  h2::before,
  h2::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 50px;
    height: 1px;
    background: #111;
    opacity: 0.2;
  }

  h2::before { left: -60px; }
  h2::after { right: -60px; }

  .card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 18px;
    padding: 25px;
    line-height: 1.75;
    box-shadow: 0 10px 30px rgba(0,0,0,0.04);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 15px;
  }

  .box {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 14px;
    padding: 20px;
    text-align: left;
    transition: 0.2s;
    line-height: 1.5;
  }

  .box:hover {
